{
  "name": "geocalc-workbench",
  "private": true,
  "version": "0.1.0",
  "description": "A scalable Earth calculator workbench prototype inspired by a GIS algorithm platform.",
  "workspaces": [
    "apps/web",
    "apps/api",
    "packages/shared"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:web dev:api",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:api": "npm --workspace apps/api run dev",
    "build": "npm-run-all --serial build:shared build:web build:api",
    "build:web": "npm --workspace apps/web run build",
    "build:api": "npm --workspace apps/api run build",
    "build:shared": "npm --workspace packages/shared run build",
    "typecheck": "npm-run-all --serial build:shared typecheck:all",
    "typecheck:all": "npm-run-all --parallel typecheck:web typecheck:api typecheck:shared",
    "typecheck:web": "npm --workspace apps/web run typecheck",
    "typecheck:api": "npm --workspace apps/api run typecheck",
    "typecheck:shared": "npm --workspace packages/shared run typecheck"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
